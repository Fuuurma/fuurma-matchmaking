{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "fuurma-matchmaking",
  "main": "src/index.ts",
  "compatibility_date": "2026-07-10",
  "compatibility_flags": ["nodejs_compat"],
  "dev": {
    "ip": "127.0.0.1",
    "port": 8787
  },
  "observability": {
    "enabled": true,
    "head_sampling_rate": 1
  },
  "durable_objects": {
    "bindings": [
      {
        "name": "MATCHMAKING_QUEUES",
        "class_name": "MatchmakingQueues"
      },
      {
        "name": "GAME_ROOM",
        "class_name": "GameRoomDO"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["MatchmakingQueues"]
    },
    {
      "tag": "v2",
      "new_sqlite_classes": ["GameRoomDO"]
    }
  ]
}
