{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "fuurma-matchmaking",
  "main": "src/index.ts",
  "compatibility_date": "2026-07-10",
  "compatibility_flags": ["nodejs_compat"],
  "durable_objects": {
    "bindings": [
      {
        "name": "MATCHMAKING_QUEUES",
        "class_name": "MatchmakingQueues"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["MatchmakingQueues"]
    }
  ]
}
